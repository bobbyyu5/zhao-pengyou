# ── Front-end (Vite) — set in Vercel project env, build-time ──────────────────
# URL of the deployed realtime server (Railway). Leave blank to disable online play.
VITE_SERVER_URL=https://your-server.up.railway.app
# Optional: override where new card-back designs are fetched from (defaults to ./card-backs.json)
# VITE_CARD_BACKS_URL=https://your-cdn/card-backs.json

# ── Server (Railway) — set in Railway service variables ───────────────────────
# Allowed CORS origin for the client (your Vercel domain). "*" works but is less strict.
CLIENT_ORIGIN=https://your-app.vercel.app
# PORT is provided by Railway automatically; these are optional tunables (ms):
# BID_WINDOW_MS=12000
# BOT_DELAY_MS=700
# TURN_TIMEOUT_MS=45000

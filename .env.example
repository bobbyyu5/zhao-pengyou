# ── Front-end (Vite) — set in Vercel project env, build-time ──────────────────
# URL of the deployed realtime server (Railway). Leave blank to disable online play.
VITE_SERVER_URL=https://your-server.up.railway.app
# Optional: override where new card-back designs are fetched from (defaults to ./card-backs.json)
# VITE_CARD_BACKS_URL=https://your-cdn/card-backs.json

# TURN relay for video on strict/cellular networks (STUN-only works on most home wifi).
# Free option: metered.ca "Open Relay" → create a free app, copy its TURN credentials here.
# Comma-separate the URLs. If any of these are blank, the app just uses STUN.
VITE_TURN_URLS=turn:standard.relay.metered.ca:80,turn:standard.relay.metered.ca:443,turns:standard.relay.metered.ca:443?transport=tcp
VITE_TURN_USERNAME=your_turn_username
VITE_TURN_CREDENTIAL=your_turn_credential

# ── Server (Railway) — set in Railway service variables ───────────────────────
# Allowed CORS origin for the client (your Vercel domain). "*" works but is less strict.
CLIENT_ORIGIN=https://your-app.vercel.app
# PORT is provided by Railway automatically; these are optional tunables (ms):
# BID_WINDOW_MS=12000
# BOT_DELAY_MS=700
# TURN_TIMEOUT_MS=45000

# ── AdMob (native Android build only — ads never show on the web PWA) ──────────
# From your AdMob account. Until set, the app uses Google's TEST ad unit (safe, no revenue).
# Also put the App ID in capacitor.config.json (plugins.AdMob.applicationId).
VITE_ADMOB_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
